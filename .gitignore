# CustomUI .gitignore — ignore local artifacts and game logs

# OS
Thumbs.db
desktop.ini

# Editor
.vscode/
*.code-workspace
.claude/
.cursor/

# Logs and temp
*.log
*.tmp
logs/

# Build / export artifacts
NO_DEHASH/
__pycache__/

# Backup files
*.bak
*.old

# Windows thumbnail cache
ehthumbs.db

# Ignore user-specific settings
*.user

# Documentation
**/*.md
!**/README.md
