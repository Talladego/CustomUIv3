<?xml version="1.0" encoding="UTF-8"?>

<Interface xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <Scripts>
        <Script file="Source/CustomUISettingsWindowTabbed.lua" />
    </Scripts>
    <Windows>

        <!-- Settings Window -->
        <Window name="CustomUISettingsWindowTabbed" movable="true" savesettings="false" layer="secondary">
            <Size>
                <AbsPoint x="900" y="800" />
            </Size>
            <Anchors>
                <Anchor point="center" relativePoint="center" />
            </Anchors>
            <EventHandlers>
                <EventHandler event="OnInitialize" function="CustomUISettingsWindowTabbed.Initialize" />
                <EventHandler event="OnKeyEnter" function="CustomUISettingsWindowTabbed.OnCancelButton" />
                <EventHandler event="OnShown" function="CustomUISettingsWindowTabbed.OnShow" />
                <EventHandler event="OnHidden" function="WindowUtils.OnHidden" />
            </EventHandlers>
            <Windows>
                <Window name="$parentBackground" inherits="EA_Window_DefaultBackgroundFrame" />
                <Window name="$parentTitleBar" inherits="EA_TitleBar_Default" />                
                <DynamicImage name="$parentWindowImage" inherits="EA_Default_SettingsImage" />
                <Button name="$parentClose" inherits="EA_Button_DefaultWindowClose" >
                    <EventHandlers>
                        <EventHandler event="OnLButtonUp" function="CustomUISettingsWindowTabbed.OnCancelButton" />
                    </EventHandlers>
                </Button>
                
                <!-- Buttons -->
                <Window name="$parentButtonBackground" inherits="EA_Window_DefaultButtonBottomFrame" layer="background" >
                    <Size>
                        <AbsPoint x="0" y="75" />
                    </Size>
                </Window>
                

                
                <!-- Tabs  -->
                <Window name="$parentTabButtons">
                    <Size>
                        <AbsPoint x="625" y="35" />
                    </Size>
                    <Anchors>
                        <Anchor point="bottomleft" relativePoint="topleft" relativeTo="$parentTitleBar"/>
                        <Anchor point="bottomright" relativePoint="topright" relativeTo="$parentTitleBar"/>
                    </Anchors>

                    <FullResizeImage name="$parentBackground" inherits="EA_FullResizeImage_MetalFill">
                        <Anchors>
                            <Anchor point="topleft" relativePoint="topleft" relativeTo="$parent"/>
                            <Anchor point="bottomright" relativePoint="bottomright" relativeTo="$parent"/>
                        </Anchors>
                    </FullResizeImage>
                    <Windows>
                        <Window name="$parentSeparatorLeft" inherits="EA_Window_TabSeparatorLeftSide" layer="background" popable="false">
                            <Anchors>
                                <Anchor point="bottomleft" relativePoint="bottomleft">
                                    <AbsPoint x="0" y="-6" />
                                </Anchor>
                                <Anchor point="bottomleft" relativePoint="topright" relativeTo="$parentPlayer">
                                    <AbsPoint x="0" y="-6" />
                                </Anchor>
                            </Anchors>
                        </Window>

                        <Button name="$parentPlayer" inherits="CustomUI_Templates_SettingsWindowTabButton" id="1">
                            <Anchors>
                                <Anchor point="topleft" relativePoint="topleft">
                                    <AbsPoint x="25" y="0" />
                                </Anchor>
                            </Anchors>
                        </Button>
                        <Button name="$parentTarget" inherits="CustomUI_Templates_SettingsWindowTabButton" id="2">
                            <Anchors>
                                <Anchor point="right" relativePoint="left" relativeTo="$parentPlayer">
                                    <AbsPoint x="0" y="0" />
                                </Anchor>
                            </Anchors>
                        </Button>
                        <Button name="$parentTargetHUD" inherits="CustomUI_Templates_SettingsWindowTabButton" id="3">
                            <Anchors>
                                <Anchor point="right" relativePoint="left" relativeTo="$parentTarget">
                                    <AbsPoint x="0" y="0" />
                                </Anchor>
                            </Anchors>
                        </Button>
                        <Button name="$parentGroup" inherits="CustomUI_Templates_SettingsWindowTabButton" id="4">
                            <Anchors>
                                <Anchor point="right" relativePoint="left" relativeTo="$parentTargetHUD">
                                    <AbsPoint x="0" y="0" />
                                </Anchor>
                            </Anchors>
                        </Button>
                        <Button name="$parentUnitFrames" inherits="CustomUI_Templates_SettingsWindowTabButton" id="5">
                            <Anchors>
                                <Anchor point="right" relativePoint="left" relativeTo="$parentGroup">
                                    <AbsPoint x="0" y="0" />
                                </Anchor>
                            </Anchors>
                        </Button>
                        <Button name="$parentGroupIcons" inherits="CustomUI_Templates_SettingsWindowTabButton" id="6">
                            <Anchors>
                                <Anchor point="right" relativePoint="left" relativeTo="$parentUnitFrames">
                                    <AbsPoint x="0" y="0" />
                                </Anchor>
                            </Anchors>
                        </Button>
                        <Button name="$parentSCT" inherits="CustomUI_Templates_SettingsWindowTabButton" id="7">
                            <Anchors>
                                <Anchor point="right" relativePoint="left" relativeTo="$parentGroupIcons">
                                    <AbsPoint x="0" y="0" />
                                </Anchor>
                            </Anchors>
                        </Button>

		                <Window name="$parentSeparatorRight" inherits="EA_Window_TabSeparatorRightSide" layer="background" popable="false">
		                  <Anchors>
		                    <Anchor point="bottomright" relativePoint="topleft" relativeTo="$parentSCT">
		                      <AbsPoint x="0" y="-6" />
		                    </Anchor>
		                    <Anchor point="bottomright" relativePoint="bottomright" >
		                      <AbsPoint x="0" y="-6" />
		                    </Anchor>
		                  </Anchors>
                        </Window>
                    </Windows>
                </Window>
                <!-- Tabs End -->


                <Window name="CustomUISettingsWindowTabbedSocket" handleinput="false" popable="false">
                    <Anchors>
                        <Anchor point="bottomleft" relativePoint="topleft" relativeTo="$parentTabButtons" >
                            <AbsPoint x="15" y="15" />
                        </Anchor>
                        <Anchor point="topright" relativePoint="bottomright" relativeTo="$parentButtonBackground" >
                            <AbsPoint x="-5" y="10" />
                        </Anchor>
                    </Anchors>
                    
                </Window>
                <Window name ="SWTabPlayer" inherits ="CustomUISettingsWindowTabPlayer"/>
                <Window name ="SWTabTarget" inherits ="CustomUISettingsWindowTabTarget"/>
                <Window name ="SWTabTargetHUD" inherits ="CustomUISettingsWindowTabTargetHUD"/>
                <Window name ="SWTabGroup" inherits ="CustomUISettingsWindowTabGroup"/>
                <Window name ="SWTabUnitFrames" inherits ="CustomUISettingsWindowTabUnitFrames"/>
                <Window name ="SWTabGroupIcons" inherits ="CustomUISettingsWindowTabGroupIcons"/>  
                <Window name ="SWTabSCT" inherits ="CustomUISettingsWindowTabSCT"/>  				
                
                
                <Button name="$parentOkayButton" inherits="EA_Button_DefaultResizeable" >
                    <Anchors>
                        <Anchor point="bottomleft" relativePoint="bottomleft" relativeTo="CustomUISettingsWindowTabbed">
                            <AbsPoint x="15" y="-10" />
                        </Anchor>
                    </Anchors>
                    <EventHandlers>
                        <EventHandler event="OnLButtonUp" function="CustomUISettingsWindowTabbed.OnOkayButton" />
                    </EventHandlers>
                </Button>
                <Button name="$parentApplyButton" inherits="EA_Button_DefaultResizeable">
                    <Anchors>
                        <Anchor point="right" relativePoint="left" relativeTo="$parentOkayButton">
                            <AbsPoint x="5" y="0" />
                        </Anchor>
                    </Anchors>
                    <EventHandlers>
                        <EventHandler event="OnLButtonUp" function="CustomUISettingsWindowTabbed.OnApplyButton" />
                    </EventHandlers>
                </Button>
                <Button name="$parentResetButton" inherits="EA_Button_DefaultResizeable">
                    <Anchors>
                        <Anchor point="right" relativePoint="left" relativeTo="$parentApplyButton">
                            <AbsPoint x="5" y="0" />
                        </Anchor>
                    </Anchors>
                    <EventHandlers>
                        <EventHandler event="OnLButtonUp" function="CustomUISettingsWindowTabbed.OnResetButton" />
                    </EventHandlers>
                </Button>
                <Button name="$parentCancelButton" inherits="EA_Button_DefaultResizeable" >
                    <Anchors>
                        <Anchor point="right" relativePoint="left" relativeTo="$parentResetButton">
                            <AbsPoint x="5" y="0" />
                        </Anchor>
                    </Anchors>
                    <EventHandlers>
                        <EventHandler event="OnLButtonUp" function="CustomUISettingsWindowTabbed.OnCancelButton" />
                    </EventHandlers>
                </Button>

                <!-- SCT color palette: last child of the settings window so it sorts above tab content + bottom buttons; `handleinput` must be true. Lua anchors to the swatch by name. -->
                <Window name="$parentSctColorPickerHost" handleinput="true" layer="popup" popable="false" >
                    <Size>
                        <!-- 192 = 16+160+16. 360: grid + gap + Default button (~35: EA_Button_DefaultResizeable 9-slice is 39px in stock) + bottom inset. -->
                        <AbsPoint x="192" y="360" />
                    </Size>
                    <Anchors>
                        <Anchor point="topleft" relativePoint="topleft" relativeTo="$parent">
                            <AbsPoint x="0" y="0" />
                        </Anchor>
                    </Anchors>
                    <Windows>
                        <FullResizeImage name="$parentSctColorPickerBackground" inherits="EA_FullResizeImage_MetalFill" handleinput="false" layer="background" alpha="1.0" >
                            <Anchors>
                                <Anchor point="topleft" relativePoint="topleft" relativeTo="$parent">
                                    <AbsPoint x="6" y="6" />
                                </Anchor>
                                <Anchor point="bottomright" relativePoint="bottomright" relativeTo="$parent">
                                    <AbsPoint x="-6" y="-6" />
                                </Anchor>
                            </Anchors>
                        </FullResizeImage>
                        <FullResizeImage name="$parentSctColorPickerBorder" inherits="EA_FullResizeImage_TanBorder" handleinput="false" layer="background" >
                            <Anchors>
                                <Anchor point="topleft" relativePoint="topleft" relativeTo="$parent">
                                    <AbsPoint x="6" y="6" />
                                </Anchor>
                                <Anchor point="bottomright" relativePoint="bottomright" relativeTo="$parent">
                                    <AbsPoint x="-6" y="-6" />
                                </Anchor>
                            </Anchors>
                        </FullResizeImage>
                        <ColorPicker name="$parentSctColorPicker" texture="EA_HUD_01" columnsPerRow="5" handleinput="true" layer="default" >
                            <Size>
                                <AbsPoint x="160" y="262" />
                            </Size>
                            <Anchors>
                                <Anchor point="topleft" relativePoint="topleft" relativeTo="$parent">
                                    <AbsPoint x="16" y="16" />
                                </Anchor>
                            </Anchors>
                            <ColorSpacing x="10" y="10" />
                            <ColorTexCoords x="304" y="450" />
                            <ColorTexDims x="24" y="24" />
                            <ColorSize x="24" y="24" />
                            <EventHandlers>
                                <EventHandler event="OnLButtonUp" function="CustomUISettingsWindowTabSCT.OnSctColorPickerLButtonUp" />
                                <EventHandler event="OnRButtonUp" function="CustomUISettingsWindowTabSCT.OnSctColorPickerRButtonUp" />
                            </EventHandlers>
                        </ColorPicker>
                        <!-- Preset 1 (engine default); same as R-click on the grid. -->
                        <Button name="$parentSctColorPickerDefaultButton" inherits="EA_Button_DefaultResizeable" textalign="center" layer="default" >
                            <Size>
                                <!-- Stock template is 39px tall; shorter sizes squash the 9-slice and draw past the window rect (clipped by parent). -->
                                <AbsPoint x="100" y="35" />
                            </Size>
                            <Anchors>
                                <!-- Same pattern as stock UI (e.g. ror_votewindow timer): bottom↔bottom keeps the control centered on the host width. -->
                                <Anchor point="bottom" relativePoint="bottom" relativeTo="$parent">
                                    <AbsPoint x="0" y="-28" />
                                </Anchor>
                            </Anchors>
                            <EventHandlers>
                                <EventHandler event="OnLButtonUp" function="CustomUISettingsWindowTabSCT.OnSctColorPickerDefaultButtonLButtonUp" />
                            </EventHandlers>
                        </Button>
                    </Windows>
                </Window>
                
            </Windows>
        </Window>
    </Windows>
</Interface>
