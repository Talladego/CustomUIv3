<Interface xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <Windows>

        <!--
            Outer height = frame (48) + gap below (50) = 98 for AttachWindowToWorldObject.
            Career icon is smaller than the ring and both centered on Content so Round-Swatch-Selection-Ring
            scales outside the icon (slice art is inset vs same-sized square).
            Lua applies WindowSetDimensions / anchors from constants.
        -->
        <!-- Root layer background so world markers stay below HUD using popup/overlay (e.g. TargetHUD). -->
        <Window name="CustomUIGroupIcon" handleinput="false" layer="background">
            <Size>
                <AbsPoint x="48" y="98" />
            </Size>
            <Windows>
                <Window name="$parentContent" handleinput="false">
                    <Size>
                        <AbsPoint x="48" y="48" />
                    </Size>
                    <Anchors>
                        <Anchor point="topleft" relativePoint="topleft" />
                    </Anchors>
                    <Windows>
                        <!-- No TexDims: atlas cell size set in Lua (DynamicImageSetTextureDimensions). -->
                        <DynamicImage name="$parentIcon" handleinput="false" textureScale="1.0" filtering="true">
                            <Size>
                                <AbsPoint x="34" y="34" />
                            </Size>
                            <Anchors>
                                <Anchor point="center" relativePoint="center" />
                            </Anchors>
                        </DynamicImage>
                        <!-- Ring: atlas UV + TexDims set in Lua (slice 38×38 @ 295,475 on EA_HUD_01). -->
                        <DynamicImage name="$parentRing" handleinput="false" layer="secondary" popable="false" textureScale="1.0" filtering="true">
                            <Size>
                                <AbsPoint x="48" y="48" />
                            </Size>
                            <Anchors>
                                <Anchor point="center" relativePoint="center" />
                            </Anchors>
                        </DynamicImage>
                        <!-- WarbandLeaderCrown: Lua positions topleft from Content (crown bottom = ring top); UV in controller. -->
                        <DynamicImage name="$parentWarbandCrown" handleinput="false" layer="secondary" popable="false" textureScale="1.0" filtering="true">
                            <Size>
                                <AbsPoint x="25" y="16" />
                            </Size>
                            <Anchors>
                                <Anchor point="topleft" relativePoint="topleft" />
                            </Anchors>
                        </DynamicImage>
                    </Windows>
                </Window>
            </Windows>
        </Window>

        <!-- Probe: invisible anchor used by Controller to validate outsider worldObj positions (never attach roster icons here). -->
        <Window name="CustomUIGroupIconsWorldProbe" handleinput="false" layer="background" parent="Root" movable="false">
            <Size>
                <AbsPoint x="0" y="0" />
            </Size>
            <Anchors>
                <Anchor point="topleft" relativePoint="topleft" relativeTo="Root" />
            </Anchors>
        </Window>

        <!-- Driver: OnUpdate tick for outsider polling + deferred TargetInfo classification (must stay parented to Root). -->
        <Window name="CustomUIGroupIconsDriver" handleinput="false" layer="background" parent="Root" movable="false">
            <Size>
                <AbsPoint x="1" y="1" />
            </Size>
            <Anchors>
                <Anchor point="topleft" relativePoint="topleft" relativeTo="Root" />
            </Anchors>
            <EventHandlers>
                <EventHandler event="OnUpdate" function="CustomUI.GroupIcons.OnUpdate" />
            </EventHandlers>
        </Window>

    </Windows>
</Interface>
