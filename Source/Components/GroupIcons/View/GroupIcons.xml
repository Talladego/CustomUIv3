<Interface xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <Windows>

        <!--
            GroupIcon world-object window template. Outer height = icon (40) + gap below (50) = 90
            so AttachWindowToWorldObject(outer) has correct bounds. Content+Icon = 40×40 at top; Lua
            may set dimensions from constants (c_ICON_SIZE, c_OUTER_H).
        -->
        <Window name="CustomUIGroupIcon">
            <Size>
                <AbsPoint x="40" y="90" />
            </Size>
            <Windows>
                <Window name="$parentContent" handleinput="true">
                    <Size>
                        <AbsPoint x="40" y="40" />
                    </Size>
                    <Anchors>
                        <Anchor point="topleft" relativePoint="topleft" />
                    </Anchors>
                    <Windows>
                        <!-- No TexDims: same idea as stock CareerIcon; atlas cell size is set in Lua (DynamicImageSetTextureDimensions). -->
                        <DynamicImage name="$parentIcon" handleinput="false" textureScale="1.0" filtering="true">
                            <Size>
                                <AbsPoint x="40" y="40" />
                            </Size>
                            <Anchors>
                                <Anchor point="topleft" relativePoint="topleft" />
                            </Anchors>
                        </DynamicImage>
                    </Windows>
                    <EventHandlers>
                        <EventHandler event="OnLButtonDown" function="CustomUI.GroupIcons.OnIconClicked" />
                    </EventHandlers>
                </Window>
            </Windows>
        </Window>

    </Windows>
</Interface>
