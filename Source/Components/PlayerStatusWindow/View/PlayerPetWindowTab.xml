<Interface xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <!-- LEGACY (removal candidate) — not loaded from CustomUI.mod; orphaned. Shipped: CustomUISettingsWindow. See README "Legacy code". -->
    <Windows>

        <Window name="CustomUIPlayerPetWindowTab" movable="false" savesettings="false" hidden="true">
            <Windows>

                <Button name="$parentEnableCheckBox" inherits="EA_Button_DefaultCheckBox">
                    <Anchors>
                        <Anchor point="topleft" relativePoint="topleft">
                            <AbsPoint x="20" y="20" />
                        </Anchor>
                    </Anchors>
                    <EventHandlers>
                        <EventHandler event="OnLButtonUp" function="CustomUI.PlayerPetWindow.Tab.OnToggleEnable" />
                    </EventHandlers>
                </Button>

                <Label name="$parentEnableLabel" inherits="EA_Label_DefaultText">
                    <Size>
                        <AbsPoint x="200" y="24" />
                    </Size>
                    <Anchors>
                        <Anchor point="topright" relativePoint="topleft" relativeTo="$parentEnableCheckBox">
                            <AbsPoint x="4" y="0" />
                        </Anchor>
                    </Anchors>
                </Label>

                <HorizontalResizeImage name="$parentEnableDivider" inherits="EA_BrownHorizontalRule">
                    <Anchors>
                        <Anchor point="topleft"  relativePoint="topleft">  <AbsPoint x="10" y="48" /></Anchor>
                        <Anchor point="topright" relativePoint="topright"> <AbsPoint x="-10" y="48" /></Anchor>
                    </Anchors>
                </HorizontalResizeImage>

            </Windows>
        </Window>

    </Windows>
</Interface>
