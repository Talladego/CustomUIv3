<Interface xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <Windows>
        <!-- Copy of EASystem_EventText `EA_Window_EventTextLabel` with left-aligned text.
             Ability icons are separate windows parented to this label's parent and anchored to this label
             (Labels cannot host child windows in the RoR client). -->
        <Label name="CustomUI_Window_EventTextLabel" font="font_default_text_large" maxchars="32" textalign="left" layer="default"
                autoresize="false" sticky="false" handleinput="false" wordwrap="false" ignoreFormattingTags="false" >
            <Size>
                <AbsPoint x="400" y="100" />
            </Size>
            <Color r="255" g="255" b="255" a="255" />
        </Label>
    </Windows>
</Interface>
