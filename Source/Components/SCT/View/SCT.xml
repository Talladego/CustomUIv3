<Interface xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <Windows>

        <!-- Placeholder root window for the SCT component.
             layer="background": SCT event trackers (scrolling combat text) should render below primary
             UI windows (GroupWindow, TargetWindow) and menus (SettingsWindow on "secondary").
             This prevents SCT text from capturing layer priority or blocking menu interactions. -->
        <Window name="CustomUISCTWindow" movable="false" savesettings="false" hidden="true" layer="background">
            <EventHandlers>
                <EventHandler event="OnUpdate" function="CustomUI.SCT.OnUpdate" />
                <EventHandler event="OnShutdown" function="CustomUI.SCT.OnShutdown" />
            </EventHandlers>
        </Window>

    </Windows>
</Interface>
