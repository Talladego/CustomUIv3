<Interface xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../Interface.xsd">
    <Windows>

        <!-- CustomUIBGMember: EA_BattlegroupHUD-style row; contour + target/mouseover rings; distant → Clock icon (Lua). -->

        <!-- ========================================================= -->
        <!-- UnitFrames HP bar art: match EA_BattlegroupHUD slices      -->
        <!-- Foreground = current HP (green), Background = missing HP  -->
        <!-- ========================================================= -->

        <HorizontalResizeImage name="CustomUIUnitFramesHPBarFilled" texture="EA_HUD_01" slice="Player-Health" alpha="1.0" textureScale="2.75">
            <Size>
                <AbsPoint x="73" y="55" />
            </Size>
            <Sizes left="0" middle="73" right="0" />
            <TexSlices>
                <Middle id="Player-Health" />
            </TexSlices>
        </HorizontalResizeImage>

        <HorizontalResizeImage name="CustomUIUnitFramesHPBarBackground" texture="EA_HUD_01" slice="Enemy-Health" alpha="1.0" textureScale="2.75">
            <Size>
                <AbsPoint x="73" y="55" />
            </Size>
            <Sizes left="0" middle="73" right="0" />
            <TexSlices>
                <Middle id="Enemy-Health" />
            </TexSlices>
        </HorizontalResizeImage>

        <StatusBar name="CustomUIUnitFramesHPBar" layer="background"
                   background="CustomUIUnitFramesHPBarBackground"
                   foreground="CustomUIUnitFramesHPBarFilled"
                   reverseFill="false" interpolate="true">
            <Size>
                <AbsPoint x="135" y="55" />
            </Size>
        </StatusBar>

        <!-- Target HUD HP: same CastBar strip as foreground + background (like Player-Health + Enemy-Health). Foreground = current HP (archetype tint); background = missing HP (red tint in Lua). -->
        <HorizontalResizeImage name="CustomUIUnitFramesHPBarTargetHudForeground" texture="EA_HUD_01" slice="CastBar" alpha="1.0" textureScale="3.928571">
            <Size>
                <AbsPoint x="50" y="55" />
            </Size>
            <Sizes left="0" middle="50" right="0" />
            <TexSlices>
                <Middle id="CastBar" />
            </TexSlices>
        </HorizontalResizeImage>
        <HorizontalResizeImage name="CustomUIUnitFramesHPBarTargetHudBackground" texture="EA_HUD_01" slice="CastBar" alpha="1.0" textureScale="3.928571">
            <Size>
                <AbsPoint x="50" y="55" />
            </Size>
            <Sizes left="0" middle="50" right="0" />
            <TexSlices>
                <Middle id="CastBar" />
            </TexSlices>
        </HorizontalResizeImage>
        <StatusBar name="CustomUIUnitFramesHPBarTargetHud" layer="background"
                   background="CustomUIUnitFramesHPBarTargetHudBackground"
                   foreground="CustomUIUnitFramesHPBarTargetHudForeground"
                   reverseFill="false" interpolate="true">
            <Size>
                <AbsPoint x="135" y="55" />
            </Size>
        </StatusBar>

        <Window name="CustomUIBGMember" popable="false" handleinput="true">
            <Size>
                <AbsPoint x="139" y="55"/>
            </Size>
            <EventHandlers>
                <EventHandler event="OnLButtonUp" function="CustomUI.UnitFrames.OnMemberLeftClick" />
                <EventHandler event="OnRButtonUp" function="CustomUI.UnitFrames.OnMemberRightClick" />
                <EventHandler event="OnMouseOver" function="CustomUI.UnitFrames.OnMemberMouseOver" />
                <EventHandler event="OnMouseOverEnd" function="CustomUI.UnitFrames.OnMemberMouseOverEnd" />
            </EventHandlers>
            <Windows>
                <FullResizeImage name="$parentBackground" inherits="EA_FullResizeImage_TintableSolidBackground" alpha="0.25">
                    <Anchors>
                        <Anchor point="topleft" relativePoint="topleft" relativeTo="">
                            <AbsPoint x="0" y="0"/>
                        </Anchor>
                        <Anchor point="bottomright" relativePoint="bottomright" relativeTo="">
                            <AbsPoint x="0" y="0"/>
                        </Anchor>
                    </Anchors>
                    <TintColor r="0" g="0" b="0" />
                </FullResizeImage>

                <FullResizeImage name="$parentDimOverlay" inherits="EA_FullResizeImage_TintableSolidBackground" alpha="0.5" layer="default" handleinput="false" show="false">
                    <Anchors>
                        <Anchor point="topleft" relativePoint="topleft" relativeTo="$parent" />
                        <Anchor point="bottomright" relativePoint="bottomright" relativeTo="$parent" />
                    </Anchors>
                    <TintColor r="0" g="0" b="0" />
                </FullResizeImage>

                <StatusBar name="$parentHPBar" inherits="CustomUIUnitFramesHPBar" popable="false" layer="background" interpolate="true">
                    <Size>
                        <AbsPoint x="135" y="55" />
                    </Size>
                    <Anchors>
                        <Anchor point="top" relativePoint="top" relativeTo="$parent">
                            <AbsPoint x="0" y="0" />
                        </Anchor>
                    </Anchors>
                </StatusBar>
                <StatusBar name="$parentHPBarTargetHud" inherits="CustomUIUnitFramesHPBarTargetHud" popable="false" layer="background" interpolate="true" show="false">
                    <Size>
                        <AbsPoint x="135" y="55" />
                    </Size>
                    <Anchors>
                        <Anchor point="top" relativePoint="top" relativeTo="$parent">
                            <AbsPoint x="0" y="0" />
                        </Anchor>
                    </Anchors>
                </StatusBar>

                <StatusBar name="$parentAPBar" inherits="UnitFrameAPStatusBar" popable="false" layer="background" interpolate="true">
                    <Size>
                        <AbsPoint x="135" y="8" />
                    </Size>
                    <Anchors>
                        <Anchor point="bottomleft" relativePoint="bottomleft" relativeTo="$parent">
                            <AbsPoint x="0" y="-2" />
                        </Anchor>
                    </Anchors>
                </StatusBar>

                <!-- Health row below 20px name strip (same vertical slot as before LabelName was reordered). -->
                <Label name="$parentLabelHealth" font="font_clear_small_bold" textalign="center" layer="secondary" handleinput="false">
                    <Size>
                        <AbsPoint x="135" y="20" />
                    </Size>
                    <Anchors>
                        <Anchor point="top" relativePoint="top" relativeTo="$parent">
                            <AbsPoint x="0" y="20"/>
                        </Anchor>
                    </Anchors>
                    <Color r="255" g="255" b="255" a="255" />
                </Label>

                <!-- Distant: Clock slice replaces health text -->
                <DynamicImage name="$parentDistantIcon" texture="EA_HUD_01" slice="Clock" layer="secondary" handleinput="false" show="false" textureScale="1.0">
                    <Size>
                        <AbsPoint x="22" y="23" />
                    </Size>
                    <Anchors>
                        <Anchor point="center" relativePoint="center" relativeTo="$parentLabelHealth" />
                    </Anchors>
                </DynamicImage>

                <!-- Dead: skull centered in health label area -->
                <DynamicImage name="$parentSkullIcon" inherits="MainAssistCrown" popable="false" handleinput="false" layer="secondary" show="false">
                    <Anchors>
                        <Anchor point="center" relativePoint="center" relativeTo="$parentLabelHealth" />
                    </Anchors>
                </DynamicImage>

                <!-- Career portrait: icon below ring in layer stack (default → secondary). Same pattern as GroupIcons Content Icon + Ring; popable=false so clicks do not raise the icon above the ring. -->
                <DynamicImage name="$parentCareerIcon" textureScale="1.0" filtering="true" handleinput="true" layer="default" popable="false">
                    <Size>
                        <AbsPoint x="30" y="30" />
                    </Size>
                    <Anchors>
                        <Anchor point="center" relativePoint="center" relativeTo="$parentCareerIconRing" />
                    </Anchors>
                    <EventHandlers>
                        <EventHandler event="OnMouseOver" function="CustomUI.UnitFrames.OnMouseOverCareerIcon" />
                    </EventHandlers>
                </DynamicImage>
                <DynamicImage name="$parentCareerIconRing" handleinput="false" layer="secondary" popable="false" textureScale="1.0" filtering="true" show="false">
                    <Size>
                        <AbsPoint x="42" y="42" />
                    </Size>
                    <Anchors>
                        <Anchor point="left" relativePoint="left" relativeTo="$parentHPBar">
                            <AbsPoint x="0" y="0" />
                        </Anchor>
                    </Anchors>
                </DynamicImage>

                <!-- Name above career ring/icon overlap (overlay); still below ContourBorder / highlight frames. -->
                <Label name="$parentLabelName" font="font_heading_unitframe_con" textalign="center" layer="overlay" handleinput="false">
                    <Size>
                        <AbsPoint x="135" y="20" />
                    </Size>
                    <Anchors>
                        <Anchor point="top" relativePoint="top" relativeTo="$parent">
                            <AbsPoint x="0" y="0"/>
                        </Anchor>
                    </Anchors>
                </Label>

                <!-- Permanent black contour (drawn under target / mouseover rings) -->
                <Window name="$parentContourBorder" layer="overlay" handleinput="false" show="true">
                    <Anchors>
                        <Anchor point="topleft" relativePoint="topleft" relativeTo="$parent">
                            <AbsPoint x="0" y="0"/>
                        </Anchor>
                        <Anchor point="bottomright" relativePoint="bottomright" relativeTo="$parent">
                            <AbsPoint x="0" y="0"/>
                        </Anchor>
                    </Anchors>
                    <Windows>
                        <DynamicImage name="$parentRing" texture="EA_HUD_01" slice="WarbandUnitFrame-Frame" layer="overlay" alpha="0.92" handleinput="false">
                            <Size>
                                <AbsPoint x="139" y="55"/>
                            </Size>
                            <Anchors>
                                <Anchor point="topleft" relativePoint="topleft" relativeTo="$parent">
                                    <AbsPoint x="0" y="0"/>
                                </Anchor>
                            </Anchors>
                            <TintColor r="0" g="0" b="0" />
                        </DynamicImage>
                    </Windows>
                </Window>

                <!-- Target highlight: same approach as EA_BattlegroupHUD (ring frame) -->
                <Window name="$parentTargetBorder" layer="overlay" handleinput="false" show="false">
                    <Anchors>
                        <Anchor point="topleft" relativePoint="topleft" relativeTo="$parent">
                            <AbsPoint x="0" y="0"/>
                        </Anchor>
                        <Anchor point="bottomright" relativePoint="bottomright" relativeTo="$parent">
                            <AbsPoint x="0" y="0"/>
                        </Anchor>
                    </Anchors>
                    <Windows>
                        <DynamicImage name="$parentRing" texture="EA_HUD_01" slice="WarbandUnitFrame-Frame" layer="overlay" alpha="0.95" handleinput="false">
                            <Size>
                                <AbsPoint x="139" y="55"/>
                            </Size>
                            <Anchors>
                                <Anchor point="topleft" relativePoint="topleft" relativeTo="$parent">
                                    <AbsPoint x="0" y="0"/>
                                </Anchor>
                            </Anchors>
                            <TintColor r="255" g="215" b="0" />
                        </DynamicImage>
                    </Windows>
                </Window>

                <!-- Mouseover highlight: lightweight ring frame -->
                <Window name="$parentMouseOverBorder" layer="overlay" handleinput="false" show="false">
                    <Anchors>
                        <Anchor point="topleft" relativePoint="topleft" relativeTo="$parent">
                            <AbsPoint x="0" y="0"/>
                        </Anchor>
                        <Anchor point="bottomright" relativePoint="bottomright" relativeTo="$parent">
                            <AbsPoint x="0" y="0"/>
                        </Anchor>
                    </Anchors>
                    <Windows>
                        <DynamicImage name="$parentRing" texture="EA_HUD_01" slice="WarbandUnitFrame-Frame" layer="overlay" alpha="0.55" handleinput="false">
                            <Size>
                                <AbsPoint x="139" y="55"/>
                            </Size>
                            <Anchors>
                                <Anchor point="topleft" relativePoint="topleft" relativeTo="$parent">
                                    <AbsPoint x="0" y="0"/>
                                </Anchor>
                            </Anchors>
                            <TintColor r="255" g="255" b="255" />
                        </DynamicImage>
                    </Windows>
                </Window>

                <!-- Career rank per member row (Lua): party / warband / scenario — UnitFramesController.ApplyMemberCareerRankLabel -->
                <Label name="$parentLabelCareerRank" font="font_clear_small_bold" textalign="right" layer="popup" handleinput="false" maxchars="4" show="false">
                    <Size>
                        <AbsPoint x="34" y="16" />
                    </Size>
                    <Anchors>
                        <Anchor point="bottomright" relativePoint="bottomright" relativeTo="$parent">
                            <AbsPoint x="-3" y="-3" />
                        </Anchor>
                    </Anchors>
                    <Color r="255" g="255" b="255" a="255" />
                </Label>
            </Windows>
        </Window>

        <Window name="CustomUIBGGroup" popable="false" movable="false" layer="default">
            <Size>
                <AbsPoint x="139" y="330"/>
            </Size>
            <Windows>
                <Window name="$parentMember1" inherits="CustomUIBGMember">
                    <Anchors>
                        <Anchor point="topleft" relativePoint="topleft" relativeTo="$parent">
                            <AbsPoint x="0" y="0" />
                        </Anchor>
                    </Anchors>
                </Window>
                <Window name="$parentMember2" inherits="CustomUIBGMember">
                    <Anchors>
                        <Anchor point="bottomleft" relativePoint="topleft" relativeTo="$parentMember1">
                            <AbsPoint x="0" y="0" />
                        </Anchor>
                    </Anchors>
                </Window>
                <Window name="$parentMember3" inherits="CustomUIBGMember">
                    <Anchors>
                        <Anchor point="bottomleft" relativePoint="topleft" relativeTo="$parentMember2">
                            <AbsPoint x="0" y="0" />
                        </Anchor>
                    </Anchors>
                </Window>
                <Window name="$parentMember4" inherits="CustomUIBGMember">
                    <Anchors>
                        <Anchor point="bottomleft" relativePoint="topleft" relativeTo="$parentMember3">
                            <AbsPoint x="0" y="0" />
                        </Anchor>
                    </Anchors>
                </Window>
                <Window name="$parentMember5" inherits="CustomUIBGMember">
                    <Anchors>
                        <Anchor point="bottomleft" relativePoint="topleft" relativeTo="$parentMember4">
                            <AbsPoint x="0" y="0" />
                        </Anchor>
                    </Anchors>
                </Window>
                <Window name="$parentMember6" inherits="CustomUIBGMember">
                    <Anchors>
                        <Anchor point="bottomleft" relativePoint="topleft" relativeTo="$parentMember5">
                            <AbsPoint x="0" y="0" />
                        </Anchor>
                    </Anchors>
                </Window>

                <!-- Lua LayoutUnitFramesLeaderCrownOnCareerRing: anchors to leader row CareerIconRing (GroupIcons-style crown above ring, scaled for smaller UF icon). -->
                <DynamicImage name="$parentGroupLeaderIcon" inherits="WarbandLeaderCrown" handleinput="false" layer="secondary" popable="false">
                    <Anchors>
                        <Anchor point="topleft" relativePoint="topleft" relativeTo="$parent">
                            <AbsPoint x="0" y="0" />
                        </Anchor>
                    </Anchors>
                </DynamicImage>
            </Windows>
        </Window>

        <!-- OnUpdate driver: must stay visible while UnitFrames is enabled (hidden windows often get no OnUpdate). -->
        <Window name="CustomUIUnitFramesRoot" movable="false" layer="background" parent="Root" handleinput="false" popable="false">
            <Size>
                <AbsPoint x="1" y="1" />
            </Size>
            <Anchors>
                <Anchor point="topleft" relativePoint="topleft" relativeTo="Root" />
            </Anchors>
            <EventHandlers>
                <EventHandler event="OnInitialize" function="CustomUI.UnitFrames.InitializeWindow" />
                <EventHandler event="OnShutdown" function="CustomUI.UnitFrames.ShutdownWindow" />
                <EventHandler event="OnUpdate" function="CustomUI.UnitFrames.Update" />
            </EventHandlers>
        </Window>

        <Window name="CustomUIUnitFramesGroup1Window" inherits="CustomUIBGGroup" savesettings="true">
            <Anchors>
                <Anchor point="bottomleft" relativePoint="topleft" relativeTo="PlayerWindow">
                    <AbsPoint x="0" y="60" />
                </Anchor>
            </Anchors>
        </Window>

        <Window name="CustomUIUnitFramesGroup2Window" inherits="CustomUIBGGroup" savesettings="true">
            <Anchors>
                <Anchor point="bottomleft" relativePoint="topleft" relativeTo="CustomUIUnitFramesGroup1Window">
                    <AbsPoint x="0" y="15" />
                </Anchor>
            </Anchors>
        </Window>

        <Window name="CustomUIUnitFramesGroup3Window" inherits="CustomUIBGGroup" savesettings="true">
            <Anchors>
                <Anchor point="topright" relativePoint="topleft" relativeTo="CustomUIUnitFramesGroup1Window">
                    <AbsPoint x="5" y="0" />
                </Anchor>
            </Anchors>
        </Window>

        <Window name="CustomUIUnitFramesGroup4Window" inherits="CustomUIBGGroup" savesettings="true">
            <Anchors>
                <Anchor point="bottomleft" relativePoint="topleft" relativeTo="CustomUIUnitFramesGroup3Window">
                    <AbsPoint x="0" y="15" />
                </Anchor>
            </Anchors>
        </Window>

        <Window name="CustomUIUnitFramesGroup5Window" inherits="CustomUIBGGroup" savesettings="true">
            <Anchors>
                <Anchor point="topright" relativePoint="topleft" relativeTo="CustomUIUnitFramesGroup3Window">
                    <AbsPoint x="5" y="0" />
                </Anchor>
            </Anchors>
        </Window>

        <Window name="CustomUIUnitFramesGroup6Window" inherits="CustomUIBGGroup" savesettings="true">
            <Anchors>
                <Anchor point="bottomleft" relativePoint="topleft" relativeTo="CustomUIUnitFramesGroup5Window">
                    <AbsPoint x="0" y="15" />
                </Anchor>
            </Anchors>
        </Window>

    </Windows>
</Interface>
