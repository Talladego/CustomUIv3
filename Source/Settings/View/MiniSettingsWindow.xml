<Interface xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../Interface.xsd">
    <Scripts>
        <Script file="Source/Settings/View/MiniSettingsWindow.lua" />
    </Scripts>
    <Windows>

        <!-- Label template (matches ChatFiltersChannelLabelTemplate) -->
        <Label name="CustomUIMiniSettingsLabelTemplate" maxchars="64" wordwrap="false" inherits="DefaultWindowText" textalign="leftcenter">
        </Label>

        <!-- Row template: outer Button receives clicks, children are visual only -->
        <Button name="CustomUIMiniSettingsRowTemplate" inherits="DefaultButton" drawchildrenfirst="true">
            <Size>
                <AbsPoint x="230" y="28" />
            </Size>
            <TextColors>
                <Normal r="255" g="255" b="255" a="255" />
                <NormalHighlit r="250" g="213" b="63" a="255" />
                <Pressed r="250" g="213" b="63" a="255" />
                <PressedHighlit r="250" g="213" b="63" a="255" />
                <Disabled r="92" g="92" b="92" a="255" />
            </TextColors>
            <EventHandlers>
                <EventHandler event="OnLButtonUp" function="CustomUI.MiniSettingsWindow.OnToggleComponent" />
            </EventHandlers>
            <Windows>
                <Label name="$parentComponentName" inherits="CustomUIMiniSettingsLabelTemplate" handleinput="false">
                    <Size>
                        <AbsPoint x="200" y="24" />
                    </Size>
                    <Anchors>
                        <Anchor point="right" relativePoint="left" relativeTo="$parentCheckBox">
                            <AbsPoint x="10" y="0" />
                        </Anchor>
                    </Anchors>
                </Label>
                <Button name="$parentCheckBox" inherits="EA_Button_DefaultCheckBox" handleinput="false">
                    <Anchors>
                        <Anchor point="topleft" relativePoint="topleft">
                            <AbsPoint x="0" y="4" />
                        </Anchor>
                    </Anchors>
                </Button>
            </Windows>
        </Button>

        <!-- Main window (matches ChatFiltersWindow exactly) -->
        <Window name="CustomUIMiniSettingsWindow" movable="true" layer="secondary">
            <Size>
                <AbsPoint x="315" y="400" />
            </Size>
            <Anchors>
                <Anchor point="center" relativePoint="center" relativeTo="">
                    <AbsPoint x="0" y="0" />
                </Anchor>
            </Anchors>
            <EventHandlers>
                <EventHandler event="OnInitialize" function="CustomUI.MiniSettingsWindow.Initialize" />
                <EventHandler event="OnShutdown"   function="CustomUI.MiniSettingsWindow.Shutdown" />
                <EventHandler event="OnShown"       function="CustomUI.MiniSettingsWindow.OnShown" />
                <EventHandler event="OnHidden"      function="CustomUI.MiniSettingsWindow.OnHidden" />
            </EventHandlers>
            <Windows>

                <Window name="$parentBackground" inherits="EA_Window_DefaultFrame">
                    <Anchors>
                        <Anchor point="topleft" relativePoint="topleft">
                            <AbsPoint x="0" y="32" />
                        </Anchor>
                        <Anchor point="bottomright" relativePoint="bottomright" />
                    </Anchors>
                </Window>

                <Window name="$parentTitleBar" inherits="EA_TitleBar_Default" />

                <Button name="$parentClose" inherits="EA_Button_DefaultWindowClose">
                    <EventHandlers>
                        <EventHandler event="OnLButtonUp" function="CustomUI.MiniSettingsWindow.Hide" />
                    </EventHandlers>
                </Button>

                <Window name="$parentButtonBackground" inherits="EA_Window_DefaultButtonBottomFrame" layer="background">
                    <Size>
                        <AbsPoint x="0" y="75" />
                    </Size>
                </Window>

                <Button name="$parentResetButton" inherits="EA_Button_DefaultResizeable" font="font_chat_text" textalign="center">
                    <Anchors>
                        <Anchor point="top" relativePoint="top" relativeTo="$parentButtonBackground">
                            <AbsPoint x="0" y="25" />
                        </Anchor>
                    </Anchors>
                    <EventHandlers>
                        <EventHandler event="OnLButtonUp" function="CustomUI.MiniSettingsWindow.ResetAllToDefaults" />
                    </EventHandlers>
                </Button>

                <Window name="$parentDescriptionSeperator" inherits="EA_Window_DefaultSeparator" handleinput="false">
                    <Anchors>
                        <Anchor point="bottomleft" relativePoint="bottomleft" relativeTo="$parentTitleBar">
                            <AbsPoint x="0" y="48" />
                        </Anchor>
                        <Anchor point="bottomright" relativePoint="bottomright" relativeTo="$parentTitleBar">
                            <AbsPoint x="0" y="48" />
                        </Anchor>
                    </Anchors>
                </Window>

                <Label name="$parentHeaderLabel" inherits="EA_Label_DefaultText">
                    <Size>
                        <AbsPoint x="250" y="30" />
                    </Size>
                    <Anchors>
                        <Anchor point="topleft" relativePoint="topleft" relativeTo="$parentDescriptionSeperator">
                            <AbsPoint x="0" y="-38" />
                        </Anchor>
                        <Anchor point="bottomright" relativePoint="bottomright" relativeTo="$parentDescriptionSeperator">
                            <AbsPoint x="0" y="-5" />
                        </Anchor>
                    </Anchors>
                </Label>

                <ListBox name="$parentList" scrollbar="EA_ScrollBar_DefaultVerticalChain" rowdef="CustomUIMiniSettingsRowTemplate" visiblerows="10" rowcount="50" rowspacing="0">
                    <Anchors>
                        <Anchor point="topleft" relativePoint="topleft" relativeTo="">
                            <AbsPoint x="10" y="75" />
                        </Anchor>
                        <Anchor point="topright" relativePoint="bottomright" relativeTo="$parentButtonBackground">
                            <AbsPoint x="-5" y="8" />
                        </Anchor>
                    </Anchors>
                    <ListData table="MiniSettingsData.rowListData" populationfunction="MiniSettingsData.PopulateRow">
                        <ListColumns>
                            <ListColumn windowname="ComponentName" variable="componentName" format="wstring" />
                        </ListColumns>
                    </ListData>
                </ListBox>

            </Windows>
        </Window>

    </Windows>
</Interface>
