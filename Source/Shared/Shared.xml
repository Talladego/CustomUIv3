<Interface xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <!-- Source/Shared/Shared.xml — current (shipped). Buff slot parent template for CustomUI.BuffTracker. See README "Source/Shared". -->
    <Windows>

                <!-- Blank container used by CustomUI.BuffTracker as the slot parent window.
                         Created at runtime under Root, then anchored relative to the owning component. -->
        <!-- default: same compositing tier as TargetUnitFrame / GroupMemberUnitFrame roots (below secondary: settings, Tome, map). -->
        <Window name="CustomUIBuffContainerTemplate" movable="false" savesettings="false" handleinput="true" layer="default">
            <Size>
                <AbsPoint x="1" y="1" />
            </Size>
        </Window>

        <!-- Driver: OnUpdate tick for global frame updates (e.g. rate-limiting TargetInfo:UpdateFromClient) -->
        <Window name="CustomUIGlobalUpdateDriver" handleinput="false" layer="background" parent="Root" movable="false">
            <Size>
                <AbsPoint x="1" y="1" />
            </Size>
            <Anchors>
                <Anchor point="topleft" relativePoint="topleft" relativeTo="Root" />
            </Anchors>
            <EventHandlers>
                <EventHandler event="OnUpdate" function="CustomUI.OnGlobalUpdate" />
            </EventHandlers>
        </Window>

    </Windows>
</Interface>
